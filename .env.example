# OpenStream Configuration
# Copy this file to .env and fill in your values

# TMDB API Key - get one free at https://www.themoviedb.org/settings/api
TMDB_KEY=your_tmdb_api_key_here

# Streamo Backend URLs
MOONLIGHT_URL=https://api.streamotv.org/moonlight
STREAMO_ORIGIN=https://streamotv.org

# Cloudflare Turnstile Sitekey (from Streamo's frontend)
TURNSTILE_SITEKEY=0x4AAAAAABdgSEeKP-qeo1HN

# Server port
PORT=3000
